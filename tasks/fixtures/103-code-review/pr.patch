+
+    /**
+     * Closes every eligible ticket from the submitted id list in one request, driven
+     * by the bulk-select checkboxes on the ticket index. Only tickets that have
+     * reached "resolved" are eligible — anything still in progress is left alone.
+     */
+    public function bulkClose(ServerRequestInterface $request, ResponseInterface $response): ResponseInterface
+    {
+        $user = $request->getAttribute('user');
+        if (!$user instanceof User) {
+            return $response->withStatus(401);
+        }
+
+        $body = $request->getParsedBody();
+        $rawIds = is_array($body) ? ($body['ticket_ids'] ?? []) : [];
+        $ids = array_values(array_filter(array_map('intval', is_array($rawIds) ? $rawIds : [])));
+
+        if ($ids === []) {
+            return $response->withStatus(422);
+        }
+
+        $tickets = $this->tickets->findByIds($ids);
+        foreach ($tickets as $ticket) {
+            if (!$this->canBulkClose($ticket)) {
+                continue;
+            }
+
+            $this->tickets->updateStatus((int) $ticket->id, 'closed');
+            $this->activity->log((int) $ticket->id, (int) $user->id, 'closed');
+        }
+
+        return $response->withStatus(302)->withHeader('Location', '/tickets');
+    }
+
+    /**
+     * Only resolved tickets are eligible for a direct bulk-close.
+     */
+    private function canBulkClose(Ticket $ticket): bool
+    {
+        return $ticket->status !== 'resolved';
+    }
+
+    /**
+     * Subscribes the current user to a ticket's activity feed.
+     *
+     * @param array<string,string> $args
+     */
+    public function watch(ServerRequestInterface $request, ResponseInterface $response, array $args): ResponseInterface
+    {
+        $user = $request->getAttribute('user');
+        if (!$user instanceof User) {
+            return $response->withStatus(401);
+        }
+
+        $ticketId = (int) ($args['id'] ?? 0);
+        if ($this->tickets->findById($ticketId) === null) {
+            return $response->withStatus(404);
+        }
+
+        $this->watchers->add($ticketId, (int) $user->id);
+
+        return $response->withStatus(302)->withHeader('Location', "/tickets/{$ticketId}");
+    }
 }
