@@ -0,0 +1,36 @@
+<?php
+
+declare(strict_types=1);
+
+namespace App\Domain\Repository;
+
+use PDO;
+
+final class TicketWatcherRepository
+{
+    public function __construct(private readonly PDO $pdo) {}
+
+    /**
+     * Subscribes a user to a ticket's activity. Called every time the user hits the
+     * "Watch" button on the ticket page.
+     */
+    public function add(int $ticketId, int $userId): void
+    {
+        $stmt = $this->pdo->prepare(
+            'INSERT INTO ticket_watchers (ticket_id, user_id) VALUES (:ticket, :user)'
+        );
+        $stmt->execute([':ticket' => $ticketId, ':user' => $userId]);
+    }
+
+    /**
+     * @return list<int>
+     */
+    public function userIdsForTicket(int $ticketId): array
+    {
+        $stmt = $this->pdo->prepare('SELECT user_id FROM ticket_watchers WHERE ticket_id = :ticket');
+        $stmt->execute([':ticket' => $ticketId]);
+
+        /** @var list<int> */
+        return array_map('intval', $stmt->fetchAll(PDO::FETCH_COLUMN));
+    }
+}
