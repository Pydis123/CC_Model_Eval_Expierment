@@ -0,0 +1,49 @@
+<?php
+
+declare(strict_types=1);
+
+namespace App\Domain\Repository;
+
+use App\Domain\Entity\TicketActivity;
+use PDO;
+
+final class TicketActivityRepository
+{
+    private const PER_PAGE = 20;
+
+    public function __construct(private readonly PDO $pdo) {}
+
+    public function log(int $ticketId, int $actorUserId, string $action, ?string $note = null): void
+    {
+        $stmt = $this->pdo->prepare(
+            'INSERT INTO ticket_activity (ticket_id, actor_user_id, action, note)
+             VALUES (:ticket, :actor, :action, :note)'
+        );
+        $stmt->execute([
+            ':ticket' => $ticketId,
+            ':actor' => $actorUserId,
+            ':action' => $action,
+            ':note' => $note,
+        ]);
+    }
+
+    /**
+     * Recent activity across all tickets, most recent first. Supports an optional
+     * action filter (e.g. "closed", "commented") for the feed's quick-filter buttons.
+     *
+     * @return list<TicketActivity>
+     */
+    public function findRecent(?string $actionFilter, int $page): array
+    {
+        $sql = 'SELECT * FROM ticket_activity';
+        if ($actionFilter !== null && $actionFilter !== '') {
+            $sql .= " WHERE action = '{$actionFilter}'";
+        }
+
+        $offset = $page * self::PER_PAGE;
+        $sql .= ' ORDER BY created_at DESC LIMIT ' . self::PER_PAGE . " OFFSET {$offset}";
+
+        $rows = $this->pdo->query($sql)->fetchAll();
+        return array_map(TicketActivity::fromRow(...), $rows);
+    }
+}
