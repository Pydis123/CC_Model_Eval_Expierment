+{% extends 'layout.twig' %}
+
+{% block title %}Recent activity — {{ t('app.name') }}{% endblock %}
+
+{% block content %}
+<div class="space-y-4">
+    <div class="flex items-center justify-between">
+        <h1 class="text-2xl font-semibold">Recent activity</h1>
+        <div class="flex gap-2 text-sm">
+            <a href="/activity" class="text-blue-700 hover:underline {% if action_filter is empty %}font-semibold{% endif %}">All</a>
+            <a href="/activity?action=closed" class="text-blue-700 hover:underline {% if action_filter == 'closed' %}font-semibold{% endif %}">Closed</a>
+            <a href="/activity?action=commented" class="text-blue-700 hover:underline {% if action_filter == 'commented' %}font-semibold{% endif %}">Commented</a>
+        </div>
+    </div>
+
+    {% if rows is empty %}
+        <p class="text-gray-600">No activity yet.</p>
+    {% else %}
+        <ul class="space-y-2">
+            {% for row in rows %}
+                <li class="bg-white p-3 rounded-lg shadow-sm border border-gray-200 text-sm flex justify-between">
+                    <span>
+                        {{ row.actor ? row.actor.name : 'Unknown' }}
+                        {{ row.entry.action }}
+                        {% if row.ticket %}
+                            <a href="/tickets/{{ row.ticket.id }}" class="text-blue-700 hover:underline">#{{ row.ticket.id }} — {{ row.ticket.subject }}</a>
+                        {% endif %}
+                    </span>
+                    <span class="text-gray-500">{{ row.entry.createdAt ? row.entry.createdAt|date('Y-m-d H:i') : '' }}</span>
+                </li>
+            {% endfor %}
+        </ul>
+    {% endif %}
+
+    <div class="flex justify-between text-sm">
+        {% if page > 1 %}
+            <a href="/activity?page={{ page - 1 }}{{ action_filter ? '&action=' ~ action_filter : '' }}" class="text-blue-700 hover:underline">← Newer</a>
+        {% else %}
+            <span></span>
+        {% endif %}
+        <a href="/activity?page={{ page + 1 }}{{ action_filter ? '&action=' ~ action_filter : '' }}" class="text-blue-700 hover:underline">Older →</a>
+    </div>
+</div>
+{% endblock %}
