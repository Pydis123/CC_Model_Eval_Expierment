+<?php
+
+declare(strict_types=1);
+
+namespace App\Http\Controller;
+
+use App\Domain\Repository\TicketActivityRepository;
+use App\Domain\Repository\TicketRepository;
+use App\Domain\Repository\UserRepository;
+use Psr\Http\Message\ResponseInterface;
+use Psr\Http\Message\ServerRequestInterface;
+use Slim\Views\Twig;
+
+final class ActivityController
+{
+    public function __construct(
+        private readonly TicketActivityRepository $activity,
+        private readonly TicketRepository $tickets,
+        private readonly UserRepository $users,
+        private readonly Twig $twig,
+    ) {}
+
+    public function index(ServerRequestInterface $request, ResponseInterface $response): ResponseInterface
+    {
+        $query = $request->getQueryParams();
+        $actionFilter = is_string($query['action'] ?? null) ? $query['action'] : null;
+        $page = max(1, (int) ($query['page'] ?? 1));
+
+        $entries = $this->activity->findRecent($actionFilter, $page);
+
+        $rows = [];
+        foreach ($entries as $entry) {
+            $rows[] = [
+                'entry' => $entry,
+                'ticket' => $this->tickets->findById($entry->ticketId),
+                'actor' => $this->users->findById($entry->actorUserId),
+            ];
+        }
+
+        return $this->twig->render($response, 'tickets/activity.twig', [
+            'rows' => $rows,
+            'action_filter' => $actionFilter,
+            'page' => $page,
+            'user' => $request->getAttribute('user'),
+        ]);
+    }
+}
