{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://llm-dispatch-experiment/tasks/schema.json",
    "title": "Experiment Task Definition",
    "type": "object",
    "required": [
        "id",
        "category",
        "size_estimate",
        "prompt_file",
        "max_iterations",
        "max_wall_clock_s",
        "success_criteria"
    ],
    "properties": {
        "id": {
            "type": "string",
            "pattern": "^[0-9]{3}-[a-z0-9-]+$"
        },
        "export_ref": {
            "type": "string",
            "description": "Experiment-repo ref exported into an isolated non-linked run dir (Phase 2 isolation). Absence means classic linked-worktree preparation."
        },
        "category": {
            "type": "string",
            "enum": [
                "trivial_i18n",
                "crud_addition",
                "query_optimization",
                "migration_backfill",
                "refactor",
                "bugfix_root_cause",
                "route_rbac",
                "frontend_alpine",
                "plan_review",
                "security_audit",
                "code_review",
                "architecture_decision",
                "bugfix_no_repro",
                "impl_hard"
            ]
        },
        "size_estimate": {
            "type": "string",
            "enum": ["xs", "s", "m", "l"]
        },
        "prompt_file": {
            "type": "string",
            "pattern": "\\.prompt\\.md$"
        },
        "max_iterations": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
        },
        "max_wall_clock_s": {
            "type": "integer",
            "minimum": 60,
            "maximum": 7200
        },
        "success_criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
                "type": "object",
                "required": ["type"],
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": [
                            "phpunit",
                            "query_count",
                            "smoke_no_regressions",
                            "lint",
                            "file_exists",
                            "grep_not_present",
                            "diff_size_limit",
                            "findings_score",
                            "rubric_score",
                            "regression_red_green"
                        ]
                    }
                }
            }
        }
    },
    "additionalProperties": false
}
