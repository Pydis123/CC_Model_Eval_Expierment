{% if flash_message %}
<div x-data="{ show: true }" x-init="setTimeout(() => show = false, 3000)" x-show="show" x-cloak
     x-transition:leave="transition ease-in duration-300"
     x-transition:leave-start="opacity-100"
     x-transition:leave-end="opacity-0"
     class="mb-4 px-4 py-3 rounded {% if flash_type == 'error' %}bg-red-50 text-red-800 border border-red-200{% else %}bg-green-50 text-green-800 border border-green-200{% endif %}">
    {{ flash_message }}
</div>
{% endif %}
