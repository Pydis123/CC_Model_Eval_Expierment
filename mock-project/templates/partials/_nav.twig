<nav class="bg-white shadow-sm border-b border-gray-200" x-data="{ mobileOpen: false, userOpen: false }">
    <div class="max-w-6xl mx-auto px-4">
        <div class="flex justify-between h-14 items-center">
            <div class="flex items-center gap-6">
                <a href="/tickets" class="text-lg font-semibold text-gray-900">{{ t('app.name') }}</a>
                <div class="hidden md:flex gap-4">
                    <a href="/tickets" class="text-sm text-gray-700 hover:text-gray-900">{{ t('nav.tickets') }}</a>
                    {% if user and user.role == 'admin' %}
                        <a href="/admin/users" class="text-sm text-gray-700 hover:text-gray-900">{{ t('nav.admin') }}</a>
                    {% endif %}
                </div>
            </div>
            <div class="flex items-center gap-4">
                <div class="flex gap-2 text-xs">
                    <span class="text-gray-500">{{ t('nav.language') }}:</span>
                    <a href="/locale/sv" class="{% if current_locale() == 'sv' %}font-semibold{% endif %}">SV</a>
                    <a href="/locale/en" class="{% if current_locale() == 'en' %}font-semibold{% endif %}">EN</a>
                </div>
                {% if user %}
                    <div class="relative" @click.away="userOpen = false">
                        <button type="button" @click="userOpen = !userOpen" class="text-sm text-gray-700 hover:text-gray-900">
                            {{ user.email }}
                        </button>
                        <div x-show="userOpen" x-cloak class="absolute right-0 mt-2 w-40 bg-white border border-gray-200 rounded shadow-lg">
                            <form method="post" action="/logout">
                                <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                                <button type="submit" class="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">
                                    {{ t('nav.logout') }}
                                </button>
                            </form>
                        </div>
                    </div>
                {% endif %}
                <button type="button" @click="mobileOpen = !mobileOpen" class="md:hidden text-gray-700" aria-label="Toggle navigation">
                    ☰
                </button>
            </div>
        </div>
        <div x-show="mobileOpen" x-cloak class="md:hidden pb-3 space-y-1">
            <a href="/tickets" class="block text-sm text-gray-700 hover:text-gray-900">{{ t('nav.tickets') }}</a>
            {% if user and user.role == 'admin' %}
                <a href="/admin/users" class="block text-sm text-gray-700 hover:text-gray-900">{{ t('nav.admin') }}</a>
            {% endif %}
        </div>
    </div>
</nav>
