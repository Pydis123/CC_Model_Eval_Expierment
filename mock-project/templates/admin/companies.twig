{% extends 'layout.twig' %}

{% block title %}{{ t('admin.companies.title') }} — {{ t('app.name') }}{% endblock %}

{% block content %}
<h1 class="text-2xl font-semibold mb-4">{{ t('admin.companies.title') }}</h1>
<ul class="bg-white rounded-lg shadow divide-y divide-gray-100">
    {% for c in companies %}
        <li class="px-4 py-2 text-sm">#{{ c.id }} — {{ c.name }}</li>
    {% endfor %}
</ul>
{% endblock %}
