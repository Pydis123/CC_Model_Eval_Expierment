{% extends 'layout.twig' %}

{% block title %}{{ t('tickets.new.title') }} — {{ t('app.name') }}{% endblock %}

{% block content %}
<div class="max-w-2xl mx-auto bg-white p-6 rounded-lg shadow">
    <h1 class="text-2xl font-semibold mb-4">{{ t('tickets.new.title') }}</h1>

    <form method="post" action="/tickets" class="space-y-4">
        <input type="hidden" name="_csrf" value="{{ csrf_token }}">

        <div>
            <label class="block text-sm text-gray-700 mb-1" for="subject">{{ t('tickets.new.subject_label') }}</label>
            <input id="subject" type="text" name="subject" required
                   class="w-full border border-gray-300 rounded px-3 py-2 text-sm">
        </div>

        <div>
            <label class="block text-sm text-gray-700 mb-1" for="description">{{ t('tickets.new.description_label') }}</label>
            <textarea id="description" name="description" rows="4" required
                      class="w-full border border-gray-300 rounded px-3 py-2 text-sm"></textarea>
        </div>

        <div>
            <label class="block text-sm text-gray-700 mb-1" for="category_id">{{ t('tickets.new.category_label') }}</label>
            <select id="category_id" name="category_id" required
                    class="w-full border border-gray-300 rounded px-3 py-2 text-sm">
                {% for c in categories %}
                    <option value="{{ c.id }}">{{ c.name }}</option>
                {% endfor %}
            </select>
        </div>

        <button type="submit" class="bg-blue-600 text-white rounded px-4 py-2 text-sm hover:bg-blue-700">
            {{ t('tickets.new.submit') }}
        </button>
    </form>
</div>
{% endblock %}
