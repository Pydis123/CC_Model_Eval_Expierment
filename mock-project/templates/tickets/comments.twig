{% extends 'layout.twig' %}

{% block title %}{{ t('comments.list.title') }} — #{{ ticket.id }}{% endblock %}

{% block content %}
<article class="space-y-6">
    <header>
        <a href="/tickets/{{ ticket.id }}" class="text-sm text-blue-700 hover:underline">
            ← #{{ ticket.id }} — {{ ticket.subject }}
        </a>
        <h1 class="text-2xl font-semibold mt-2">{{ t('comments.list.title') }}</h1>
        <p class="text-sm text-gray-500">{{ tp('comments.count', comments|length) }}</p>
    </header>

    {% if comments is empty %}
        <p class="text-gray-600">{{ t('comments.empty') }}</p>
    {% else %}
        <ul class="space-y-3">
            {% for c in comments %}
                <li class="bg-white p-4 rounded-lg shadow-sm border border-gray-200">
                    <p class="text-sm whitespace-pre-line">{{ c.body }}</p>
                    <p class="text-xs text-gray-500 mt-2">
                        {{ c.createdAt ? c.createdAt|date('Y-m-d H:i') : '' }}
                    </p>
                </li>
            {% endfor %}
        </ul>
    {% endif %}

    {% if user %}
        <form method="post" action="/tickets/{{ ticket.id }}/comments" class="bg-white p-4 rounded-lg shadow-sm border border-gray-200 space-y-3">
            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
            <div>
                <label class="block text-sm text-gray-700 mb-1" for="body">{{ t('comments.form.body_label') }}</label>
                <textarea id="body" name="body" rows="3" required
                          class="w-full border border-gray-300 rounded px-3 py-2 text-sm"></textarea>
            </div>
            <button type="submit" class="bg-blue-600 text-white rounded px-4 py-2 text-sm hover:bg-blue-700">
                {{ t('comments.form.submit') }}
            </button>
        </form>
    {% endif %}
</article>
{% endblock %}
