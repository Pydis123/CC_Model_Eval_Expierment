{
    "name": "llm-dispatch-experiment/mock-project",
    "description": "Support ticket system (mock project for dispatch experiment)",
    "type": "project",
    "require": {
        "php": "^8.4",
        "slim/slim": "^4.13",
        "slim/psr7": "^1.7",
        "php-di/php-di": "^7.0",
        "twig/twig": "^3.10",
        "slim/twig-view": "^3.4",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.11"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse src --level=6"
    }
}
