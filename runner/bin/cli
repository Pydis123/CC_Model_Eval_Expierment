#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/../vendor/autoload.php';

use LlmDispatch\Runner\Analysis\Aggregator;
use LlmDispatch\Runner\Analysis\BootstrapSimulator;
use LlmDispatch\Runner\Analysis\ContaminationDetector;
use LlmDispatch\Runner\Cli\Application;
use LlmDispatch\Runner\Cli\Command\EvaluateCommand;
use LlmDispatch\Runner\Cli\Command\PinCheckPingCommand;
use LlmDispatch\Runner\Cli\Command\PinCheckVerifyCommand;
use LlmDispatch\Runner\Cli\Command\ProbeQueryCountCommand;
use LlmDispatch\Runner\Cli\Command\ReportCommand;
use LlmDispatch\Runner\Cli\Command\ReportDeltaCommand;
use LlmDispatch\Runner\Cli\Command\RunAllCommand;
use LlmDispatch\Runner\Cli\Command\RunNextCommand;
use LlmDispatch\Runner\Cli\Command\StateInitCommand;
use LlmDispatch\Runner\Cli\Command\StateNextRunCommand;
use LlmDispatch\Runner\Cli\Command\StatePinModelsCommand;
use LlmDispatch\Runner\Cli\Command\StateRecordRunCommand;
use LlmDispatch\Runner\Cli\Command\StateResetStaleCommand;
use LlmDispatch\Runner\Cli\Command\ValidateTasksCommand;
use LlmDispatch\Runner\Config;
use LlmDispatch\Runner\Report\FindingsWriter;
use LlmDispatch\Runner\Dispatch\ClaudeCliResponseParser;
use LlmDispatch\Runner\Dispatch\DispatchEnvelopeBuilder;
use LlmDispatch\Runner\Dispatch\FailedChecksSummarizer;
use LlmDispatch\Runner\Dispatch\ProcessClaudeCli;
use LlmDispatch\Runner\Dispatch\RateLimitWaiter;
use LlmDispatch\Runner\Dispatch\RunCoordinator;
use LlmDispatch\Runner\Evaluator\Check\DiffSizeLimitCheck;
use LlmDispatch\Runner\Evaluator\Check\FileExistsCheck;
use LlmDispatch\Runner\Evaluator\Check\FindingsScoreCheck;
use LlmDispatch\Runner\Evaluator\Check\GrepNotPresentCheck;
use LlmDispatch\Runner\Evaluator\Check\LintCheck;
use LlmDispatch\Runner\Evaluator\Check\PhpunitCheck;
use LlmDispatch\Runner\Evaluator\Check\QueryCountCheck;
use LlmDispatch\Runner\Evaluator\Check\RegressionRedGreenCheck;
use LlmDispatch\Runner\Evaluator\Check\RubricScoreCheck;
use LlmDispatch\Runner\Evaluator\Check\SmokeNoRegressionsCheck;
use LlmDispatch\Runner\Evaluator\Evaluator;
use LlmDispatch\Runner\Execution\ConnectivityChecker;
use LlmDispatch\Runner\Execution\ConsecutiveErrorCounter;
use LlmDispatch\Runner\Execution\CrashDumper;
use LlmDispatch\Runner\Execution\OfflineGate;
use LlmDispatch\Runner\Execution\ProgressLogger;
use LlmDispatch\Runner\Execution\ResultsTailReader;
use LlmDispatch\Runner\Execution\SwapDetector;
use LlmDispatch\Runner\Execution\TaskPromptLoader;
use LlmDispatch\Runner\Judge\JudgeClient;
use LlmDispatch\Runner\Logging\ResultsLogger;
use LlmDispatch\Runner\PinCheck\PinCheckService;
use LlmDispatch\Runner\Probe\QueryCountProbe;
use LlmDispatch\Runner\State\RunQueue;
use LlmDispatch\Runner\State\StateManager;
use LlmDispatch\Runner\Support\ProcessExecutor;
use LlmDispatch\Runner\Worktree\ExportWorktreeManager;
use LlmDispatch\Runner\Worktree\WorktreeManager;

$repoRoot = dirname(__DIR__, 2);

$statePath = getenv('LLM_DISPATCH_STATE_PATH') ?: $repoRoot . '/state.json';
$resultsPath = getenv('LLM_DISPATCH_RESULTS_PATH') ?: $repoRoot . '/results/results.jsonl';

$config = Config::fromFile($repoRoot . '/experiment_config.json');
$stateManager = new StateManager($statePath);
$resultsLogger = new ResultsLogger($resultsPath);
$runQueue = new RunQueue($config);

$processExecutor = new ProcessExecutor();

// Dispatch runs with a sanitized env whose PATH excludes the claude binary
// dir (so a model cannot spawn nested claude sessions); resolve the binary to
// an ABSOLUTE path here so proc_open does not depend on the child PATH.
$claudeBinary = getenv('HOME') . '/.local/bin/claude';
if (!is_executable($claudeBinary)) {
    $resolved = trim((string) shell_exec('command -v claude 2>/dev/null'));
    $claudeBinary = $resolved !== '' ? $resolved : 'claude';
}

$judgeClient = $config->judgeModel !== null
    ? new JudgeClient(
        new ProcessClaudeCli($processExecutor, new ClaudeCliResponseParser(), $claudeBinary),
        $config->judgeModel,
        sys_get_temp_dir(),
    )
    : null;

$checkFactories = [
    'phpunit' => static fn(array $c) => new PhpunitCheck(
        filter: $c['filter'] ?? null,
        runs: (int) ($c['runs'] ?? 1),
    ),
    'query_count' => static fn(array $c) => new QueryCountCheck(
        route: (string) $c['route'],
        max: (int) $c['max'],
        authAsAdmin: (bool) ($c['auth_as_admin'] ?? true),
    ),
    'smoke_no_regressions' => static fn(array $c) => new SmokeNoRegressionsCheck(),
    'lint' => static fn(array $c) => new LintCheck(),
    'file_exists' => static fn(array $c) => new FileExistsCheck($c['paths'] ?? []),
    'grep_not_present' => static fn(array $c) => new GrepNotPresentCheck(
        pattern: (string) $c['pattern'],
        paths: (array) ($c['paths'] ?? []),
    ),
    'diff_size_limit' => static fn(array $c) => new DiffSizeLimitCheck(
        maxLines: (int) $c['max_lines'],
        baseRef: (string) ($c['base_ref'] ?? 'scaffold_complete'),
    ),
    'findings_score' => static fn(array $c) => new FindingsScoreCheck(
        groundTruthPath: $repoRoot . '/tasks/ground-truth/' . (string) $c['ground_truth'],
        artifactRelPath: (string) ($c['artifact'] ?? 'findings.json'),
        recallMin: (float) $c['recall_min'],
        precisionMin: (float) $c['precision_min'],
        findingsCap: (int) ($c['findings_cap'] ?? 25),
        judge: $judgeClient ?? throw new RuntimeException('findings_score requires judge_model in config'),
    ),
    'rubric_score' => static fn(array $c) => new RubricScoreCheck(
        rubricPath: $repoRoot . '/tasks/rubrics/' . (string) $c['rubric'],
        artifactRelPath: (string) ($c['artifact'] ?? 'decision-memo.md'),
        threshold: (int) $c['threshold'],
        judge: $judgeClient ?? throw new RuntimeException('rubric_score requires judge_model in config'),
    ),
    'regression_red_green' => static fn(array $c) => new RegressionRedGreenCheck(),
];

$evaluator = new Evaluator($checkFactories);

$claudeCli = new ProcessClaudeCli(
    $processExecutor,
    new ClaudeCliResponseParser(),
    $claudeBinary,
);

$runCoordinator = new RunCoordinator(
    cli: $claudeCli,
    evaluator: $evaluator,
    envelopeBuilder: new DispatchEnvelopeBuilder(),
    failedChecksSummarizer: new FailedChecksSummarizer(),
    rateLimitWaiter: new RateLimitWaiter(30),
    sleeper: static function (int $s): void { sleep($s); },
    now: 'time',
);

$worktreeManager = new WorktreeManager(
    executor: $processExecutor,
    repoRoot: $repoRoot,
    worktreeBaseDir: '/tmp',
    failedDir: $repoRoot . '/worktrees/failed',
    baseRef: 'scaffold_complete',
);

$exportWorktreeManager = new ExportWorktreeManager(
    executor: $processExecutor,
    repoRoot: $repoRoot,
    worktreeBaseDir: '/tmp',
    failedDir: $repoRoot . '/worktrees/failed',
    fixturesDir: $repoRoot . '/tasks/fixtures',
);

$progressLogger = new ProgressLogger($repoRoot . '/results/runner.log');
$errorCounter = new ConsecutiveErrorCounter(5);
$crashDumper = new CrashDumper($repoRoot . '/results');

$connectivity = new ConnectivityChecker();
$offlineGate = new OfflineGate($connectivity, $progressLogger, $repoRoot . '/PAUSE', static function (int $s): void { sleep($s); });

$claudeVersion = trim((string) shell_exec(escapeshellarg($claudeBinary) . ' --version 2>&1'));

$contaminationDetector = new ContaminationDetector([$repoRoot . '/tasks', 'tasks/ground-truth']);

$runNextCommand = new RunNextCommand(
    stateManager: $stateManager,
    resultsLogger: $resultsLogger,
    taskPromptLoader: new TaskPromptLoader($repoRoot . '/tasks'),
    worktreeManager: $worktreeManager,
    coordinator: $runCoordinator,
    allowedTools: ['Bash', 'Edit', 'Read', 'Write', 'Glob', 'Grep'],
    now: static fn() => (new DateTimeImmutable('now', new DateTimeZone('UTC')))->format('Y-m-d\TH:i:s\Z'),
    claudeVersion: $claudeVersion,
    exportWorktreeManager: $exportWorktreeManager,
    judgeClient: $judgeClient,
    contaminationDetector: $contaminationDetector,
);

$environment = [
    'php_version' => PHP_VERSION,
    'claude_version' => $claudeVersion,
    'experiment_commit_sha' => trim((string) shell_exec('git -C ' . escapeshellarg($repoRoot) . ' rev-parse HEAD 2>&1')),
    'hostname' => (string) gethostname(),
    'timezone' => date_default_timezone_get(),
];

$registry = [
    'state' => [
        'init' => new StateInitCommand($stateManager, $runQueue, $config->planSeed),
        'next-run' => new StateNextRunCommand($stateManager, (new DateTimeImmutable('now', new DateTimeZone('UTC')))->format('Y-m-d\TH:i:s\Z')),
        'record-run' => new StateRecordRunCommand($stateManager, $resultsLogger),
        'pin-models' => new StatePinModelsCommand($stateManager, $config->tiers),
        'reset-stale' => new StateResetStaleCommand(
            $stateManager,
            static fn() => new DateTimeImmutable('now', new DateTimeZone('UTC')),
        ),
    ],
    'evaluate' => new EvaluateCommand($repoRoot . '/tasks', $evaluator),
    'pin-check' => [
        'ping' => new PinCheckPingCommand($stateManager),
        'verify' => new PinCheckVerifyCommand($stateManager, new PinCheckService()),
    ],
    'probe' => [
        'query-count' => new ProbeQueryCountCommand(new QueryCountProbe()),
    ],
    'run-next' => $runNextCommand,
    'run-all' => new RunAllCommand(
        runNext: $runNextCommand,
        progressLogger: $progressLogger,
        errorCounter: $errorCounter,
        crashDumper: $crashDumper,
        stateManager: $stateManager,
        environment: $environment,
        swapDetector: new SwapDetector(3),
        resultsTail: new ResultsTailReader($resultsPath),
        pinnedModels: $config->pinnedModels,
        pauseSentinelPath: $repoRoot . '/PAUSE',
        offlineGate: $offlineGate,
        connectivity: $connectivity,
    ),
    'report' => new ReportCommand(
        config: $config,
        aggregator: new Aggregator(),
        simulator: new BootstrapSimulator(),
        writer: new FindingsWriter(),
        defaultInputPath: $resultsPath,
        defaultOutputPath: $repoRoot . '/docs/findings.md',
        defaultBootstrapSamples: 1000,
        defaultBootstrapSeed: $config->planSeed,
    ),
    'validate-tasks' => new ValidateTasksCommand(tasksDir: $repoRoot . '/tasks', repoRoot: $repoRoot),
    'report-delta' => new ReportDeltaCommand(
        oldPath: $repoRoot . '/results/results-v1-2026-04.jsonl',
        newPath: $resultsPath,
        outputPath: $repoRoot . '/docs/findings-delta.md',
        oldLabel: 'v1',
        newLabel: 'v2.1',
        footnote: 'Haiku is the environment-drift control (same model id in v1 and v2.1).',
    ),
];

exit((new Application($registry))->run($argv));
