{
  "name": "llm-dispatch-experiment/runner",
  "description": "Runner, evaluator and state-manager utilities for LLM dispatch experiment",
  "type": "project",
  "require": {
    "php": "^8.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "LlmDispatch\\Runner\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "LlmDispatch\\Runner\\Tests\\": "tests/"
    }
  },
  "bin": ["bin/cli"],
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
