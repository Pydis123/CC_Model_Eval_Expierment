# Aider history (om någon kör aider lokalt)
.aider*

# Personal worklog — kept locally, not pushed
/WORKLOG.md

# Internal design artifacts (plans/specs from brainstorming flow) — kept
# locally for the maintainer, not pushed. The published architecture is in
# docs/methodology.md, DECISIONS.md, and docs/conclusions.md.
/docs/superpowers/

# Experiment runtime
/worktrees/*
!/worktrees/.gitignore
*.log
/PAUSE
/results/run-all.pid

# Env secrets (om de används i framtiden)
.env
.env.local

# Docker volumes
/docker-data/

worktrees/failed/
results/runner.log
results/runner-crash-*.json

# Live campaign runtime state — mutated continuously by run-all; must NOT be
# git-tracked or a stray git reset/stash/checkout (incl. by a subagent) reverts
# the running campaign. Final data is archived as a versioned snapshot at the
# campaign boundary (e.g. results-v2.1-2026-07.jsonl).
/state.json
/results/results.jsonl
/results/contaminated/
/results/run-all-phase2.log
/results/net-keepalive.pid
